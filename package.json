    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "jszip": "^3.10.1",
    "laravel-echo": "^2.3.4",
    "pusher-js": "^8.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
